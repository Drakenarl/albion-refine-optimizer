{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cp -r src/albion_refine api/albion_refine && cd web && npm install && npm run build",
  "outputDirectory": "web/dist",
  "cleanUrls": true,
  "functions": {
    "api/index.py": {}
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" }
  ]
}
