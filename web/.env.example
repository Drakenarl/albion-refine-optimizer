# Variables du frontend Vite.
# En setup Vercel monorepo (defaut) : LAISSE VIDE. Le frontend et le backend
# vivent sur le meme domaine, /api/* est route vers la fonction serverless.
# Le proxy Vite en dev (vite.config.ts) redirige /api -> http://127.0.0.1:8000.
#
# En setup backend separe (ex. Render, Railway) : renseigne l'URL du backend,
# sans slash final :
# VITE_API_URL=https://albion-refine-api.up.railway.app

VITE_API_URL=
