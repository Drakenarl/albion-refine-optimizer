# Variables d'environnement du backend FastAPI.
# Copie ce fichier en `.env` en local, ou defini ces vars dans le dashboard
# Railway/Render pour la prod.

# Port d'ecoute (Railway/Render l'injectent automatiquement, ne pas fixer en prod).
PORT=8000

# Origines autorisees pour CORS, separees par des virgules.
# En dev : localhost Vite (defaut deja gere dans le code).
# En prod : URL du frontend Vercel, ex :
# ALBION_ALLOWED_ORIGINS=https://albion-refine.vercel.app,https://albion.mondomaine.com
ALBION_ALLOWED_ORIGINS=

# Adresse d'ecoute (utile seulement en local, la prod ecoute sur 0.0.0.0).
ALBION_API_HOST=0.0.0.0
